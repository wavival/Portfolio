---
import Button from "@/components/ui/Button.astro";
import Link from "@/components/ui/Link.astro";
---

<header class="fixed w-full top-0 z-50 backdrop-blur-md bg-[var(--nav-blur)] border-b border-[var(--border-base)]">
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" aria-label="Inicio">
  <img 
src={`${import.meta.env.BASE_URL}brand/logo-w.webp`}    alt="wavival.dev" 
    class="h-[48px] w-auto"
  />
</a>

    <ul class="hidden md:flex items-center gap-8">
      <li><Link href="#projects">Proyectos</Link></li>
      <li><Link href="#stack">Stack</Link></li>
      <li><Link href="#about">Sobre mí</Link></li>
      <li><Button icon="send-email-white" href="mailto:wavival.dev@luminaw.co">Contáctame</Button></li>
    </ul>

    <button id="menu-btn" class="md:hidden p-2 text-[var(--text-primary)]" aria-label="Abrir menú">
      ☰
    </button>
  </nav>
</header>